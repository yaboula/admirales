{
  "install_sql_automatically": true,
  "allow_second_fivem_instance": true,
  "owners": ["license2:1a3ba66e3ab1cdb37db5971d887fbfb74e94c8eb"],
  "hierarchy_protection": true,
  "default_duty": false,
  "default_dark_mode": true,
  "props_render_distance": 1000,
  "branding": {
    "name": "Admirales",
    "logo": "./server_logo.png",
    "link": "https://discord.gg/admirales"
