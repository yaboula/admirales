    "options": {
      "minZoom": 2,
      "maxZoom": 8,
      "zoom": 2,
      "center": [0, 0],
      "maxBounds": [
        [-4000, -5500],
        [8000, 6000]
      ]
    },
    "color": "rgb(15,168,210)"
