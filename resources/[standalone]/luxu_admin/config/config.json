          "noWrap": true,
          "id": "My Custom Map"
        }
      },
      "image": {
        "url": "https://imagedelivery.net/xMNIukUvBnTcljSQ6wCsQg/d69bfcd1-773e-489a-201e-6ec358ec6500/MAPS",
        "options": {
          "bounds": [
            [-4000, -5500],
            [8000, 6000]
          ]
        }
      }
